# Premier démarrage uniquement — crée le compte admin initial dans la base de données
# Ces variables sont ignorées si la base de données existe déjà
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Clé de session Flask (obligatoire)
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplace_par_une_chaine_aleatoire
